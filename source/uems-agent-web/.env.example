# ── UEMS Agent Web — Environment Configuration ─────────────────
# Copy to .env and adjust. All values below show the defaults.

# ── Server ──────────────────────────────────────────────────────
UEMS_MODE=http
UEMS_HOST=
UEMS_PORT=443

# ── Paths ───────────────────────────────────────────────────────
UEMS_REPO_DIR=data/repos
UEMS_GUIDELINES_DIR=../../guidelines
UEMS_PROMPTS_DIR=../../agents/orchestrator/agents
UEMS_REPO_DATA=../common/repos.json
UEMS_PUBLIC_DIR=../frontend

# ── Bridge mode ─────────────────────────────────────────────────
UEMS_BRIDGE_URL=

# ── Tool limits ─────────────────────────────────────────────────
UEMS_SEARCH_MAX_RESULTS=200
UEMS_TOOL_OUTPUT_LIMIT=8000
UEMS_TOOL_TIMEOUT=120
UEMS_CONTEXT_TOKEN_LIMIT=120000

# ── Rate limiting (requests-per-second / burst) ─────────────────
UEMS_RATE_LIMIT_RPS=10
UEMS_RATE_LIMIT_BURST=30
UEMS_AUTH_RATE_LIMIT_RPS=2
UEMS_AUTH_RATE_LIMIT_BURST=5

# ── Graceful shutdown ───────────────────────────────────────────
UEMS_SHUTDOWN_TIMEOUT=15

# ── GitHub / Copilot ────────────────────────────────────────────
UEMS_GITHUB_CLIENT_ID=Iv1.b507a08c87ecfe98
UEMS_COPILOT_API_BASE_URL=https://api.business.githubcopilot.com
UEMS_COPILOT_EDITOR_VERSION=vscode/1.155.0
UEMS_COPILOT_PLUGIN_VERSION=1.155.0
UEMS_GITHUB_API_VERSION=2025-04-01

# ── Cookie TTLs (seconds) ──────────────────────────────────────
UEMS_COPILOT_TOKEN_MAX_AGE=3600
UEMS_GITHUB_TOKEN_MAX_AGE=86400

# ── Frontend model configuration ───────────────────────────────
UEMS_CHAT_MODEL=claude-sonnet-4.6
UEMS_SUGGEST_MODEL=gpt-4.1
UEMS_FRONTEND_EDITOR_VERSION=vscode/1.96.0
UEMS_FRONTEND_PLUGIN_VERSION=copilot-chat/0.23.2

# ── TLS (always enforced; self-signed cert auto-generated if omitted)
# UEMS_TLS_CERT=
# UEMS_TLS_KEY=
