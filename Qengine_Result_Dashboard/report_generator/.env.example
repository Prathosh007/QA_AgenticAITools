# Zoho OAuth credentials for the QEngine API — copy to .env and fill in.
# Generate a refresh token for your client with QEngine API scope.
CLIENT_ID=1000.xxxxxxxxxxxxxxxxxxxxxxxx
CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REFRESH_TOKEN=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endpoints / defaults (.in data centre shown)
TOKEN_URL=https://accounts.zoho.in/oauth/v2/token
QENGINE_BASE=https://qengine.zoho.in/api/v1/uems
PROJECT_ID=4443000000022861

# Optional: GOAT install dir for logs/screenshots/remarks enrichment
# GOAT_HOME=D:\GOAT
